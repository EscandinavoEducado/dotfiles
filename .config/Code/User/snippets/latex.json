{
	// Place your snippets for latex here. Each snippet is defined under a snippet name and has a prefix, body and 
	// description. The prefix is what is used to trigger the snippet and the body will be expanded and inserted. Possible variables are:
	// $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. Placeholders with the 
	// same ids are connected.
	// Example:
	// "Print to console": {
	// 	"prefix": "log",
	// 	"body": [
	// 		"console.log('$1');",
	// 		"$2"
	// 	],
	// 	"description": "Log output to console"
	// }
	//
	// You can also restrict snippets to specific files using include/exclude patterns:
	// "Test snippet": {
	// 	"prefix": "test",
	// 	"body": "test('$1', () => {\n\t$0\n});",
	// 	"include": ["**/*.test.ts", "*.spec.ts"],
	// 	"exclude": ["**/temp/*.ts"],
	// 	"description": "Insert test block"
	// }
    "citeonline (simples)": {
        "prefix": "citeonline",
        "body": "\\citeonline{${1:}}",
        "description": "Citação direta (Autor, ano)"
    },
    "citeonline (com página)": {
        "prefix": "citeonline",
        "body": "\\citeonline[${1:}]{${2:}}",
        "description": "Citação direta com página (Autor, ano, p. xx)"
    },
    "linkcite (simples)": {
        "prefix": "linkcite",
        "body": "\\linkcite{${1:}}{${2:}}",
        "description": "Link citável: (Texto, ano)"
    },
    "linkcite (com página)": {
        "prefix": "linkcite",
        "body": "\\linkcite[${1:}]{${2:}}{${3:}}",
        "description": "Link citável com página: (Texto, ano, p. xx)"
    },
    "Definição Customizada": {
        "prefix": "BDEF",
        "body": [
            "\\begin{definicao}[${1:}]",
            "\t$0",
            "\t\\label{def:${2:}}",
            "\\end{definicao}"
        ],
        "description": "Cria um ambiente de Definição"
    },
    "Teorema Customizado": {
        "prefix": "BTEO",
        "body": [
            "\\begin{teorema}",
            "\t$0",
            "\t\\label{teo:${1:}}",
            "\\end{teorema}"
        ],
        "description": "Cria um ambiente de Teorema"
    },
    "Corolário Customizado": {
        "prefix": "BCOR",
        "body": [
            "\\begin{corolario}",
            "\t$0",
            "\t\\label{cor:${1:}}",
            "\\end{corolario}"
        ],
        "description": "Cria um ambiente de Corolário"
    },
    "Lema Customizado": {
        "prefix": "BLEMA",
        "body": [
            "\\begin{lema}",
            "\t$0",
            "\t\\label{lema:${1:}}",
            "\\end{lema}"
        ],
        "description": "Cria um ambiente de Lema"
    },
    "Proposição Customizada": {
        "prefix": "BPROP",
        "body": [
            "\\begin{proposicao}",
            "\t$0",
            "\t\\label{prop:${1:}}",
            "\\end{proposicao}"
        ],
        "description": "Cria um ambiente de Proposição"
    },
    "Exemplo Customizado": {
        "prefix": "BEX",
        "body": [
            "\\begin{exemplo}",
            "\t$0",
            "\t\\label{ex:${1:}}",
            "\\end{exemplo}"
        ],
        "description": "Cria um ambiente de Exemplo"
    },
    "Nota Customizada": {
        "prefix": "BNOTA",
        "body": [
            "\\begin{remark}",
            "\t$0",
            "\\end{remark}"
        ],
        "description": "Cria um ambiente de Nota"
    },
    "Demonstração Customizada": {
        "prefix": "BDEM",
        "body": [
            "\\begin{proof}",
            "\t$0",
            "\\end{proof}"
        ],
        "description": "Cria um ambiente de Demonstração"
    },
    "adjustwidth Customizada": {
        "prefix": "BAD",
        "body": [
            "\\begin{adjustwidth}{1cm}{0cm}",
            "\t$0",
            "\\end{adjustwidth}"
        ],
        "description": "Cria um ambiente de adjustwidth"
    },
}